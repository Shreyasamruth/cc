  "educational_examples": {
    "description": "Step-by-step examples for learning quantum computing",
    "examples": {
      "creating_superposition": {
        "title": "Creating Quantum Superposition",
        "steps": [
          {
            "step": 1,
            "description": "Start with qubit in |0⟩ state",
            "state": [1.0, 0.0],
            "visualization": "Bloch vector points up (north pole)"
          },
          {
            "step": 2,
            "description": "Apply Hadamard gate",
            "gate": "H",
            "state": [0.7071, 0.7071],
            "visualization": "Bloch vector points along +X axis"
          },
          {
            "step": 3,
            "description": "Measure in computational basis",
            "measurement_probabilities": {"0": 0.5, "1": 0.5},
            "note": "Equal probability of measuring 0 or 1"
          }
        ]
      },
      "quantum_interference": {
        "title": "Demonstrating Quantum Interference",
        "steps": [
          {
            "step": 1,
            "description": "Create superposition with H gate",
            "circuit": [{"gate": "H", "target": 0}],
            "state": [0.7071, 0.7071]
          },
          {
            "step": 2,
            "description": "Apply another H gate",
            "circuit": [{"gate": "H", "target": 0}],
            "state": [1.0, 0.0],
            "note": "Interference causes return to |0⟩"
          }
        ]
      },
      "entanglement_creation": {
        "title": "Creating Quantum Entanglement",
        "steps": [
          {
            "step": 1,
            "description": "Start with two qubits in |00⟩",
            "state": [1.0, 0.0, 0.0, 0.0]
          },
          {
            "step": 2,
            "description": "Put first qubit in superposition",
            "circuit": [{"gate": "H", "target": 0}],
            "state": [0.7071, 0.0, 0.7071, 0.0]
          },
          {
            "step": 3,
            "description": "Apply CNOT to create entanglement",
            "circuit": [{"gate": "CNOT", "control": 0, "target": 1}],
            "state": [0.7071, 0.0, 0.0, 0.7071],
            "note": "Now qubits are maximally entangled"
          }
        ]
      }
    }
  }
}
